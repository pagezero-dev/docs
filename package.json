{
  "name": "docs",
  "type": "module",
  "version": "0.0.1",
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "astro": "astro",
    "check": "astro check",
    "reset": "git clean -fdxq && npm i",
    "start": "wrangler dev --port 3000",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "setup": "npm install && playwright install --with-deps chromium",
    "test:e2e": "playwright test --project=e2e",
    "test:e2e:ui": "playwright test --ui --project=e2e",
    "test:smoke": "playwright test --project=smoke"
  },
  "dependencies": {
    "@astrojs/check": "0.9.4",
    "@astrojs/starlight": "0.35.2",
    "astro": "5.6.1",
    "sharp": "0.34.2",
    "typescript": "5.9.2"
  },
  "devDependencies": {
    "@playwright/test": "1.54.2",
    "prettier": "3.6.2",
    "prettier-plugin-astro": "0.14.1",
    "wrangler": "4.28.0"
  }
}
